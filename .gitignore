# ------------------------------------------------------------
# Project-wide .gitignore (monorepo root)
# ------------------------------------------------------------

# OS/editor files
.DS_Store
.idea/
.vscode/

# Dependencies
node_modules/

# Package manager artifacts
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files (keep samples like .env.example if needed)
.env*

# Build/test coverage outputs (any package)
coverage/
build/
dist/

# Backend
backend/node_modules/

# Frontend (Next.js app is nested in frontend/e_commerce)
frontend/e_commerce/node_modules/
frontend/e_commerce/.next/
frontend/e_commerce/out/
frontend/e_commerce/.vercel/
frontend/e_commerce/next-env.d.ts

# TypeScript
*.tsbuildinfo

# Optional local secrets/certs
*.pem
